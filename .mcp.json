{
  "mcpServers": {
    "goshort": {
      "command": "./bin/goshort",
      "args": ["--mcp"],
      "env": {
        "GOSHORT_STORAGE_SQLITE_PATH": "./data/goshort.db"
      }
    },
    "goshort-remote": {
      "url": "https://goshort.app/mcp",
      "headers": {
        "X-API-Key": "your-api-key"
      }
    }
  }
}
