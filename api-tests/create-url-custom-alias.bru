meta {
  name: Create URL with Custom Alias
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/v1/urls
  body: json
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "url": "https://example.com/custom",
    "custom_alias": "my-test-link"
  }
}

assert {
  res.status: eq 201
  res.body.short_code: eq my-test-link
}
