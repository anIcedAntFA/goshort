---
// Cycles: auto → light → dark
// Shows current mode icon: monitor (auto), sun (light), moon (dark)
---

<button
	class="btn btn-ghost p-2"
	data-theme-toggle
	aria-label="Toggle color theme"
>
	<!-- Auto / system -->
	<svg data-icon="auto" class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
		<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3" />
	</svg>
	<!-- Light / sun -->
	<svg data-icon="light" class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
		<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
	</svg>
	<!-- Dark / moon -->
	<svg data-icon="dark" class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
		<path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
	</svg>
</button>

<script>
	import { queryData } from '@/lib/dom';

	type Theme = 'auto' | 'light' | 'dark';
	const CYCLE: Theme[] = ['auto', 'light', 'dark'];

	function savedTheme(): Theme {
		return (localStorage.getItem('theme') as Theme | null) ?? 'auto';
	}

	function applyTheme(theme: Theme): void {
		const isDark =
			theme === 'dark' || (theme === 'auto' && matchMedia('(prefers-color-scheme:dark)').matches);
		if (isDark) {
			document.documentElement.dataset.theme = 'dark';
		} else {
			delete document.documentElement.dataset.theme;
		}
	}

	function updateIcon(theme: Theme): void {
		const btn = queryData<HTMLButtonElement>('theme-toggle');
		if (btn) btn.dataset.theme = theme;
	}

	function setTheme(theme: Theme): void {
		if (theme === 'auto') {
			localStorage.removeItem('theme');
		} else {
			localStorage.setItem('theme', theme);
		}
		applyTheme(theme);
		updateIcon(theme);
	}

	// Sync icon with current theme on load
	updateIcon(savedTheme());

	const btn = queryData<HTMLButtonElement>('theme-toggle');
	btn?.addEventListener('click', () => {
		const current = savedTheme();
		const next = CYCLE[(CYCLE.indexOf(current) + 1) % CYCLE.length];
		setTheme(next);
	});
</script>

<style>
	[data-theme-toggle] [data-icon] {
		display: none;
	}
	[data-theme-toggle][data-theme='auto'] [data-icon='auto'],
	[data-theme-toggle][data-theme='light'] [data-icon='light'],
	[data-theme-toggle][data-theme='dark'] [data-icon='dark'] {
		display: block;
	}
</style>
