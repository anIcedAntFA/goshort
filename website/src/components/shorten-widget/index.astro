---
// POST /api/v1/urls/public — no auth, 30-day expiry, honeypot spam guard.
// Set PUBLIC_API_BASE env var to override origin (e.g. http://localhost:8080 for local dev).
// Frontmatter import makes the CSS global so [data-theme="dark"] selectors are not scoped.
import './shorten-widget.css';

import Check from '@lucide/astro/icons/check';
import Copy from '@lucide/astro/icons/copy';
import Download from '@lucide/astro/icons/download';
import ExternalLink from '@lucide/astro/icons/external-link';
import Globe from '@lucide/astro/icons/globe';
import Plus from '@lucide/astro/icons/plus';
import QrCode from '@lucide/astro/icons/qr-code';
import WandSparkles from '@lucide/astro/icons/wand-sparkles';
---

<div class="w-full" data-shorten-widget>
	<form data-shorten-form novalidate>
		<!-- Honeypot: off-screen, invisible to humans, detectable by bots -->
		<div
			aria-hidden="true"
			style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden"
		>
			<input
				id="website"
				name="website"
				type="text"
				tabindex="-1"
				autocomplete="off"
				data-honeypot
			/>
		</div>

		<div class="flex gap-2">
			<input
				type="url"
				name="url"
				class="input flex-1"
				placeholder="Paste your long URL"
				required
				data-url-input
			/>
			<button type="submit" class="btn btn-primary" data-submit-btn>Shorten</button>
		</div>
	</form>

	<div class="card mt-4 hidden" data-shorten-result>
		<!-- Original URL -->
		<div class="mb-2">
			<p class="result-label"><Globe size={14} />Original URL</p>
			<p class="result-value truncate" data-original-url></p>
		</div>

		<!-- Shortened URL -->
		<div class="mb-3">
			<p class="result-label"><WandSparkles size={14} /> Shortened URL <span class="result-label-meta" data-expires-label></span></p>
			<div class="flex min-w-0 items-center gap-1">
				<a
					href=""
					target="_blank"
					rel="noopener noreferrer"
					class="min-w-0 truncate font-semibold text-brand hover:underline"
					data-short-url
				></a>
				<button class="copy-icon-btn shrink-0" data-copy-icon-btn title="Copy short URL">
					<span data-icon-copy><Copy size={14} /></span>
					<span data-icon-check><Check size={14} /></span>
				</button>
			</div>
		</div>

		<!-- Action row: Visit | QR | Copy -->
		<div class="flex gap-1.5">
			<a
				href=""
				target="_blank"
				rel="noopener noreferrer"
				class="action-btn"
				title="Open short URL in new tab"
				data-visit-link
			>
				<ExternalLink size={13} />
				<span>Visit URL</span>
			</a>
			<button class="action-btn" title="Show QR code" data-qr-btn>
				<QrCode size={13} />
				<span>QR</span>
			</button>
			<button class="action-btn" title="Copy short URL" data-copy-btn>
				<span data-icon-copy><Copy size={13} /></span>
				<span data-icon-check><Check size={13} /></span>
				<span data-copy-label>Copy</span>
			</button>
		</div>

		<!-- QR panel (fade-in/out via data-visible) -->
		<div class="qr-panel mt-3" data-qr-section>
			<div class="rounded-lg border border-border p-3 dark:border-border-dark bg-surface-alt dark:bg-surface-alt-dark">
				<p class="qr-section-label mb-3">Download Your QR Code</p>
				<div class="flex items-start gap-4">
					<div class="qr-img-wrapper">
						<img
							src=""
							alt="QR code for short URL"
							width="160"
							height="160"
							class="size-24 sm:size-32 lg:size-40 rounded"
							crossorigin="anonymous"
							data-qr-img
						/>
						<button class="qr-copy-overlay" data-copy-qr-btn title="Copy QR code to clipboard">
							<span data-icon-copy><Copy size={16} /></span>
							<span data-icon-check><Check size={16} /></span>
						</button>
					</div>
					<div class="flex gap-1 h-24 flex-1 flex-col justify-between sm:h-32 sm:gap-3 lg:h-40 lg:gap-4">
						<button class="download-qr-btn" title="Download QR code as PNG" data-download-png-btn>
							<Download size={16} />
							<span>Download PNG</span>
						</button>
						<button class="download-qr-btn" title="Download QR code as JPEG" data-download-jpeg-btn>
							<Download size={16} />
							<span>Download JPEG</span>
						</button>
						<button class="download-qr-btn" title="Download QR code as SVG" data-download-svg-btn>
							<Download size={16} />
							<span>Download SVG</span>
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Shorten another -->
		<button class="shorten-another-btn mt-4" data-shorten-another>
			<Plus size={13} />
			<span>Shorten another link</span>
		</button>
	</div>

	<p class="mt-2 min-h-5 text-sm text-danger opacity-0 transition-opacity" data-shorten-error aria-live="polite"></p>
</div>

<script src="./shorten-widget.ts"></script>
