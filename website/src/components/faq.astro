---
interface FAQItem {
	question: string;
	answer: string;
}

const items: FAQItem[] = [
	{
		question: 'Is it free?',
		answer:
			'Yes. GoShort is MIT-licensed open source — self-host it for free on any server. The live demo at goshort.ngockhoi96.dev runs on a shared instance with a 5 req/min rate limit.',
	},
	{
		question: 'Can I use my own domain for short links?',
		answer:
			'Yes. Set base_url in goshort.toml to your domain (e.g. https://go.yourco.com) and all generated links use it. Bring your own TLS via Caddy or any reverse proxy.',
	},
	{
		question: 'Does it support custom aliases like /my-link?',
		answer:
			'Yes, via the authenticated REST API or CLI: POST /api/v1/urls with a custom_alias field, or goshort-cli shorten --alias my-link. The public demo widget uses auto-generated codes only.',
	},
	{
		question: 'How many URLs can I store?',
		answer:
			'Limited only by disk space. SQLite handles millions of rows without issue. For very high write throughput, a PostgreSQL backend is on the roadmap.',
	},
	{
		question: 'Do you track my URLs or collect analytics?',
		answer:
			'No tracking, no ads, no third-party scripts. The public instance counts clicks per link — nothing else. Self-hosted instances are entirely under your control.',
	},
	{
		question: 'What happens to links after 30 days on the public demo?',
		answer:
			'Public links expire after 30 days and return 410 Gone on access. Self-hosted instances let you set any expiry — or no expiry at all.',
	},
];
---

<div class="mx-auto max-w-2xl divide-y divide-border dark:divide-border-dark">
	{
		items.map((item) => (
			<details class="group py-4" data-faq-item>
				<summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-sm font-medium text-text dark:text-text-dark">
					{item.question}
					<span class="faq-icon shrink-0 text-text-muted transition-transform dark:text-text-muted-dark">
						<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
						</svg>
					</span>
				</summary>
				<div data-faq-body>
					<p class="mt-3 pb-1 text-sm leading-relaxed text-text-muted dark:text-text-muted-dark">
						{item.answer}
					</p>
				</div>
			</details>
		))
	}
</div>

<style>
	/* Hide default marker across browsers */
	[data-faq-item] > summary {
		list-style: none;
	}
	[data-faq-item] > summary::-webkit-details-marker {
		display: none;
	}

	/* Rotate + icon to × when open */
	[data-faq-item][open] .faq-icon {
		transform: rotate(45deg);
		color: var(--color-brand);
	}
	:global([data-theme='dark']) [data-faq-item][open] .faq-icon {
		color: var(--color-brand);
	}

	/* Animated accordion body — JS drives max-height; CSS provides starting state */
	[data-faq-body] {
		overflow: hidden;
		max-height: 0;
		opacity: 0;
		transition:
			max-height 0.25s ease,
			opacity 0.2s ease;
	}
	/* CSS fallback for open state when JS hasn't run (SSR/no-JS) */
	details[open] > [data-faq-body] {
		max-height: none;
		opacity: 1;
	}
</style>

<script>
	import { queryAllData, queryData } from '@/lib/dom';

	const faqItems = queryAllData<HTMLDetailsElement>('faq-item');

	for (const details of faqItems) {
		const summary = details.querySelector('summary');
		const body = queryData<HTMLElement>('faq-body', undefined, details);
		if (!summary || !body) continue;

		summary.addEventListener('click', (e) => {
			e.preventDefault();

			if (details.open) {
				// Closing: snapshot current rendered height, force-commit it, then animate to 0
				body.style.maxHeight = `${body.scrollHeight}px`;
				body.style.opacity = '1';
				// Force reflow so browser commits the snapshot as the transition start
				// biome-ignore lint/suspicious/noExplicitAny: intentional reflow trigger
				void (body as any).offsetHeight;
				body.style.maxHeight = '0';
				body.style.opacity = '0';

				const onClose = (ev: TransitionEvent) => {
					if (ev.propertyName !== 'max-height') return;
					details.removeAttribute('open');
					body.removeEventListener('transitionend', onClose);
				};
				body.addEventListener('transitionend', onClose);
			} else {
				// Opening: set open first (needed for scrollHeight to reflect full content),
				// immediately pin to 0 via inline style to override the CSS open-state fallback,
				// force reflow to commit, then animate to full height
				details.setAttribute('open', '');
				const height = body.scrollHeight;
				body.style.maxHeight = '0';
				body.style.opacity = '0';
				// biome-ignore lint/suspicious/noExplicitAny: intentional reflow trigger
				void (body as any).offsetHeight;
				body.style.maxHeight = `${height}px`;
				body.style.opacity = '1';

				const onOpen = (ev: TransitionEvent) => {
					if (ev.propertyName !== 'max-height') return;
					// Clear inline style — CSS open-state fallback (max-height: none) takes over
					body.style.maxHeight = '';
					body.removeEventListener('transitionend', onOpen);
				};
				body.addEventListener('transitionend', onOpen);
			}
		});
	}
</script>
